# UniUltraOpenPlatForm 环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库类型: sqlite 或 postgresql
DATABASE_TYPE=sqlite

# PostgreSQL 数据库配置（仅当 DATABASE_TYPE=postgresql 时使用）
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=uni_platform
PG_USER=postgres
PG_PASSWORD=your_password_here

# 内部 API 密钥（用于 skill 调用绕过认证）
INTERNAL_API_KEY=dev-local-key

# 开发模式：跳过认证校验（生产环境设为 false）
SKIP_AUTH=true